{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "telegram-cursor-bot",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "4450cffd4f25491cc797dd112824bc72",
  "vars": {
    "ENVIRONMENT": "production",
    "WORKER_PUBLIC_URL": "https://telegram-cursor-bot.fxjournaluz.workers.dev"
  },
  "kv_namespaces": [
    {
      "binding": "SESSIONS",
      "id": "e4f1347ef43c457abe6e81f7b801e94b"
    }
  ],
  "triggers": {
    "crons": ["*/15 * * * *"]
  },
  "migrations": [
    {
      "tag": "v1-remove-pending-poller",
      "deleted_classes": ["PendingPoller"]
    }
  ]
}
