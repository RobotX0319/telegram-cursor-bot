{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "telegram-cursor-bot",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "4450cffd4f25491cc797dd112824bc72",
  "vars": {
    "ENVIRONMENT": "production",
    "WORKER_PUBLIC_URL": "https://telegram-cursor-bot.fxjournaluz.workers.dev",
    "SUPABASE_URL": "https://obmdederainzipigyuwi.supabase.co"
  },
  "kv_namespaces": [
    {
      "binding": "SESSIONS",
      "id": "e4f1347ef43c457abe6e81f7b801e94b"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "PENDING_POLLER",
        "class_name": "PendingPoller"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1-pending-poller",
      "new_sqlite_classes": ["PendingPoller"]
    }
  ],
  "triggers": {
    "crons": ["*/10 * * * *"]
  }
}
