{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "telegram-video-bot",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "ENVIRONMENT": "production",
    "WORKER_PUBLIC_URL": "https://telegram-video-bot.fxjournaluz.workers.dev",
    "WEBHOOK_KEY": "my-super-secret-abc123",
    "ADMIN_PANEL_PATH": "/admin1"
  },
  "kv_namespaces": [
    {
      "binding": "VIDEOS",
      "id": "99e4fc2121974a9ea8be15e9a7582582"
    }
  ]
}
